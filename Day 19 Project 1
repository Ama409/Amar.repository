# IMPORTING REQUIRED LIBRARIES
import pickle

# A METHOD TO GET ALL CUSTOMER's INFORMATION
def getCustomer():
    file = open("customer.bin","rb")
    cus = dict()
    try:
        while True:
            cus.update(pickle.load(file))
    except:
        pass
    file.close()
    return cus

# A METHOD TO ADD A CUSTOMER INFORMATION
def addCustomer():
    cid = input("\n\t\tEnter New Customer ID : ")
    if not getCustomer().get(cid,False):
        cname = input("\t\tEnter Customer Name : ")
        cadd = input("\t\tEnter Customer Address : ")
        cmob = input("\t\tEnter Customer Mobile Number : ")
        file = open("customer.bin" , "ab")
        data = {cid:[cname,cadd,cmob]}
        pickle.dump(data,file)
        file.close()
        print("\t\tCustomer Addedd Successfully!")
    else:
        print("\n\t\tThis ID is Already Exist!")

# A METHOD TO VIEW ALL CUSTOMER's INFORMATION
def viewCustomer():
    cus = getCustomer()
    for cid,info in cus.items():
        print("\n\t\tCustomer ID :",cid)
        print("\t\tCustomer Name :",info[0])
        print("\t\tCustomer Address :",info[1])
        print("\t\tCustomer Mobile Number :",info[2])
        print("\t\t-------------------------------------------")

