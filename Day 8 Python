WAP to count factors of a number

num = int(input("Enter A Number : "))
count = 0
a = 1
while a<=num:
    if num%a==0:
        print(a)
        count+=1
    a = a+1
print("Total Factors :",count)



WAP to check a number is Prime

num = int(input("Enter A Number : "))
count = 0
a = 1
while a<=num:
    if num%a==0:
        print(a)
        count+=1
    a = a+1
print("Total Factors :",count)
if count==2:
    print("Prime Number")
else:
    print("Not Prime Number")

